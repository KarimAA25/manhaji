# Manhaj environment variables — copy to .env (which is gitignored) and fill in.
#
# .env is loaded by the ETL (etl/load_to_postgres.py) and any future
# Python tools. Never commit .env to git.

# ============================================================================
# Supabase Postgres credentials (preferred — robust against any password)
# ============================================================================
# Why three vars instead of one URL: passwords with special characters (':',
# '@', '/', etc.) break URL parsing. Splitting the credentials into three
# fields means we never have to URL-parse anything.
#
# How to get the values:
#   1. Open https://supabase.com/dashboard → pick the manhaj project
#   2. SUPABASE_PROJECT_REF is the URL slug — for this project: dxrkbjftkfhlddqefmaq
#   3. SUPABASE_REGION is in the connection string you copied earlier.
#      Look for "aws-0-<REGION>.pooler.supabase.com" — pick the bit between
#      "aws-0-" and ".pooler". Common values: eu-central-1, ap-south-1,
#      us-east-1, eu-west-2. (If you don't know, open the Connect button on
#      the project page; the connection-pooler hostname tells you the region.)
#   4. SUPABASE_DB_PASSWORD is the database password you saved when creating
#      the project (from your password manager). Paste it raw — no encoding,
#      no quotes. Whatever characters it contains, they're fine.
SUPABASE_PROJECT_REF=dxrkbjftkfhlddqefmaq

# PREFERRED — paste the exact pooler hostname from Supabase's "Connect" modal.
# It looks like: aws-0-eu-central-1.pooler.supabase.com  OR  aws-1-ap-south-1.pooler.supabase.com
# (Supabase puts new projects on shard 0 or 1 depending on capacity — don't guess; copy.)
SUPABASE_POOLER_HOST=

# Fallback (only used if SUPABASE_POOLER_HOST is empty). Hardcodes shard 0.
# SUPABASE_REGION=

SUPABASE_DB_PASSWORD=

# ============================================================================
# DATABASE_URL — alternative single-string format (only works if password has no
# special chars like : @ / # ?). If both formats are set, the separate vars win.
# ============================================================================
# DATABASE_URL=postgresql://postgres.dxrkbjftkfhlddqefmaq:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ============================================================================
# Optional overrides
# ============================================================================
# Path to the workbook the ETL should parse (default = ~/dev/manhaj/data/source/...)
# XLSX_PATH=/absolute/path/to/timetable.xlsx

# School name (must match the row in `schools` table)
# SCHOOL_NAME=International School of Oman

# Academic year label (must match `academic_years.label`)
# ACADEMIC_YEAR_LABEL=2026-2027

# ============================================================================
# Service-role key (needed for etl/upload_source_to_supabase.py + future
# server-side jobs that bypass RLS)
# ============================================================================
# Get from: Supabase Dashboard → Settings → API → "service_role" secret
# (Supabase often hides it behind a "Reveal" button; click to see + copy.)
# NEVER commit, NEVER paste in chat. Used only by server-side jobs:
#   - etl/upload_source_to_supabase.py (Storage uploads)
#   - future monthly-report background job
#   - future ETL re-runs on the deployed server
SUPABASE_SERVICE_ROLE_KEY=
